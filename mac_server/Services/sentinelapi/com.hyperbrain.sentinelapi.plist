<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
    "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.hyperbrain.sentinelapi</string>

    <key>ProgramArguments</key>
    <array>
        <!-- Update path after first build -->
        <string>/Users/danielc/mac_server/Services/sentinelapi/.build/release/SentinelAPI</string>
        <string>serve</string>
        <string>--env</string>
        <string>production</string>
    </array>

    <key>EnvironmentVariables</key>
    <dict>
        <!-- AWS credentials for event-sentinel-api-sqs IAM user -->
        <!-- Temporary: load from ~/sentinel-sqs-key.txt until SOPS migration (TD-03) -->
        <key>AWS_ACCESS_KEY_ID</key>
        <string>REPLACE_WITH_KEY_ID</string>
        <key>AWS_SECRET_ACCESS_KEY</key>
        <string>REPLACE_WITH_SECRET</string>
        <key>AWS_REGION</key>
        <string>us-east-1</string>
        <!-- Full URL of sync-events.fifo SQS queue (provisioned in HyperBrain #26) -->
        <key>QUEUE_URL</key>
        <string>REPLACE_WITH_QUEUE_URL</string>
        <!-- Tailscale hostname of Mac Mini — never use IP (can change) -->
        <key>SENTINEL_API_BASE_URL</key>
        <string>REPLACE_WITH_TAILSCALE_HOSTNAME</string>
    </dict>

    <key>KeepAlive</key>
    <true/>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/danielc/Library/Logs/sentinelapi/sentinelapi.stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/danielc/Library/Logs/sentinelapi/sentinelapi.stderr.log</string>

    <key>WorkingDirectory</key>
    <string>/Users/danielc/mac_server/Services/sentinelapi</string>
</dict>
</plist>
